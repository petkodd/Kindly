# Kindly — environment variables (Alpha v0.1)

# PostgreSQL with pgvector. Use Neon, Supabase, or RDS on Vercel.
DATABASE_URL=postgres://user:password@host:5432/kindly

# Set to "disable" for a local Postgres without SSL.
PGSSL=

# AI provider (companion + summary). Abstraction layer reads this.
AI_API_KEY=
AI_MODEL=claude-sonnet-4-6

# Email provider (Resend). Mocked with a deterministic fake if either is unset.
EMAIL_API_KEY=
EMAIL_FROM=Kindly <hello@kindly.example.com>

# Public site URL (used for canonical/OG/sitemap).
NEXT_PUBLIC_SITE_URL=https://kindly.example.com

# Shared secret for cron job routes (/api/jobs/*). Vercel Cron sends it as
# "Authorization: Bearer <CRON_SECRET>". If unset, job routes refuse all calls.
CRON_SECRET=

# Secret used to sign buyer/admin session cookies (HMAC-SHA256). Use a long
# random value; rotating it invalidates all existing sessions. Required in prod.
SESSION_SECRET=

# Speech providers for the voice turn (/api/talk/voice).
# If either key is unset, the deterministic fake is used (local dev + tests).
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
# ElevenLabs voice ID. Default: Adam (pNInz6obpgDQGcFmaJgB).
ELEVENLABS_VOICE_ID=

# Billing (Stripe, test mode). The 7-day free trial (card required upfront)
# is built on Checkout + a webhook. Without STRIPE_SECRET_KEY / a plan's
# Price id, the checkout route degrades to a 503 rather than crashing local
# dev/build. See src/lib/billing/config.ts for the single place all of these
# are read and resolved to a PLAN_PRICE_IDS lookup.
#
# Secret key for the Stripe API (test mode). Use a restricted key (rk_...)
# scoped to Checkout Sessions/Subscriptions/Webhooks where possible.
STRIPE_SECRET_KEY=
# Signing secret for the /api/billing/webhook endpoint. In local dev, get one
# from `stripe listen --forward-to localhost:3000/api/billing/webhook`.
STRIPE_WEBHOOK_SECRET=
# Family Companion plan — monthly recurring Price id. Manual step: name this
# Price's Product "Family Companion" (or equivalent) in the Stripe dashboard
# so it matches the marketing copy in src/lib/content.ts PRICING and doesn't
# drift again — this repo has already shipped and fixed that exact mismatch
# once (see commits 59e1323, e5c5f13).
STRIPE_PRICE_FAMILY_MONTHLY=
# Family Companion plan — annual recurring Price id. Must be the SAME
# Product as STRIPE_PRICE_FAMILY_MONTHLY, a second recurring Price with a
# 1-year interval — not a separate Product.
STRIPE_PRICE_FAMILY_ANNUAL=
# Premium Care plan — monthly recurring Price id.
STRIPE_PRICE_PREMIUM_MONTHLY=
# Premium Care plan — annual recurring Price id. Must be the SAME Product as
# STRIPE_PRICE_PREMIUM_MONTHLY, not a separate Product.
STRIPE_PRICE_PREMIUM_ANNUAL=
# Gift Package — one-time Price id for the 3-month prepaid gift.
STRIPE_PRICE_GIFT_3MONTH=
# Founding Facility Pilot — one-time Price id for the B2B pilot offer.
STRIPE_PRICE_FACILITY_PILOT=

# Error tracking (Sentry). SDK stays idle with no DSN set — safe to leave
# empty in local dev. NEXT_PUBLIC_SENTRY_DSN is for the browser; SENTRY_DSN
# for server/edge. Sentry never receives request bodies (sendDefaultPii: false).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Only needed to upload source maps at build time (nicer stack traces); build
# succeeds without them.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
